# Hugging Face dataset (https://huggingface.co/datasets/ManikaSaini/zomato-restaurant-recommendation)
HF_DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation

# Optional: local path for preprocessed cache (parquet/json)
# DATA_CACHE_PATH=data/processed/restaurants.parquet

# LLM — Groq (https://console.groq.com/)
LLM_PROVIDER=groq
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_TIMEOUT_SECONDS=30

# Max restaurants sent to the LLM after filtering (token/cost guardrail)
MAX_CANDIDATES_FOR_LLM=25
